# 1. استخدام نسخة Alpine خفيفة لتقليل مساحة الحاوية وتقليص ثغرات النظام (Attack Surface)
FROM node:20-alpine

# 2. تحديث حزم النظام الأساسية وتنزيل الرقع الأمنية فوراً لتجنب الثغرات المعروفة
RUN apk update && apk upgrade --no-cache

# 3. تحديد مجلد العمل داخل الحاوية لضمان تنظيم الملفات وعزلها
WORKDIR /usr/src/app

# 4. نسخ ملفات الاعتمادات والمكتبات أولاً للاستفادة من ميزة الـ Caching وتسريع البناء
COPY package*.json ./

# 5. تثبيت المكتبات الخاصة بالإنتاج فقط (Production) لمنع نزول أدوات التطوير الزائدة
RUN npm ci --only=production

# 6. نسخ بقية ملفات المشروع والكود المصدري إلى الحاوية
COPY . .

# 7. تطبيق مبدأ الصلاحيات الأقل (Least Privilege) وتشغيل التطبيق بمستخدم محدود الصلاحيات
# هنا نتحول من مستخدم root الفائق إلى مستخدم node الآمن لمنع اختراق السيرفر
USER node

# 8. تحديد المنفذ (Port) الذي سيعمل عليه التطبيق لتسهيل عملية الربط الشبكي
EXPOSE 3000

# 9. الأمر النهائي لتشغيل خادم التطبيق بشكل آمن ومباشر
CMD ["node", "server.js"]
